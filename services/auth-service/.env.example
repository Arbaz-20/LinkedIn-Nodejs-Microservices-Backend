NODE_ENV=development
PORT=3001
SERVICE_NAME=auth-service

DATABASE_URL=postgresql://linkedin:linkedin_pg_password@localhost:5432/auth_db
RABBITMQ_URL=amqp://linkedin:linkedin_rabbitmq_password@localhost:5672
REDIS_URL=redis://:linkedin_redis_password@localhost:6379

JWT_ACCESS_SECRET=your-access-secret-min-32-chars-change-me
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

CLIENT_URL=http://localhost:5173
# COOKIE_DOMAIN=.example.com

# Postgres TLS (production)
# DB_SSL=true
# DB_SSL_NO_VERIFY=false
