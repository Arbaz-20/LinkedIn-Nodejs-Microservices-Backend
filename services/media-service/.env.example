NODE_ENV=development
PORT=3008
SERVICE_NAME=media-service

DATABASE_URL=postgresql://linkedin:linkedin_pg_password@localhost:5432/media_db
RABBITMQ_URL=amqp://linkedin:linkedin_rabbitmq_password@localhost:5672
REDIS_URL=redis://:linkedin_redis_password@localhost:6379

CLIENT_URL=http://localhost:5173

# MinIO / S3-compatible object storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=linkedin_minio_access
MINIO_SECRET_KEY=linkedin_minio_secret
MINIO_BUCKET=uploads
MINIO_PUBLIC_URL=http://localhost:9000

# Postgres TLS (production)
# DB_SSL=true
# DB_SSL_NO_VERIFY=false
