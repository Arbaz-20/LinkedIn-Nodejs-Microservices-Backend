NODE_ENV=development
PORT=3006
SERVICE_NAME=notification-service

DATABASE_URL=postgresql://linkedin:linkedin_pg_password@localhost:5432/notification_db
RABBITMQ_URL=amqp://linkedin:linkedin_rabbitmq_password@localhost:5672
REDIS_URL=redis://:linkedin_redis_password@localhost:6379

CLIENT_URL=http://localhost:5173

# SMTP (transactional email). If SMTP_HOST is unset, email is a no-op.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=secret
EMAIL_FROM=no-reply@linkedin-clone.local

# Postgres TLS (production)
# DB_SSL=true
# DB_SSL_NO_VERIFY=false
